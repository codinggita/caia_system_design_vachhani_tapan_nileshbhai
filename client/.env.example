# CAIA System Design Client - Environment Variables Example
# Copy this file to '.env' for local production preview builds.
# DO NOT commit '.env' files to Git repository.

# URL pointing to your deployed Render Backend API (remember to append '/api/v1')
# For example: https://caia-system-design-backend.onrender.com/api/v1
VITE_API_URL=http://localhost:5000/api/v1
